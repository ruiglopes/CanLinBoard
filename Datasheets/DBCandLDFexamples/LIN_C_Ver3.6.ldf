		HVCH_RESP1			delay	20.000	ms;
		HVCH_RESP2			delay	20.000	ms;
		BLWR_CTRL1_RESP		delay	20.000	ms;
		BLWR_CTRL2_REQ		delay	20.000	ms;
		FBH_WEBASTO_RESP	delay	20.000	ms;
		BLWR_CTRL2_RESP		delay	20.000	ms;
		EAC_REQ				delay	20.000	ms;
		EAC_RESP			delay	20.000	ms;
		HVCH_REQ			delay	20.000	ms;
		HVCH_RESP1			delay	20.000	ms;
		HVCH_RESP2			delay	20.000	ms;
		TELESTART_01_REQ	delay	20.000	ms;
		TELESTART_01_RESP	delay	20.000	ms;
		TELESTART_02_REQ	delay	20.000	ms;
		TELESTART_02_RESP	delay	20.000	ms;
	}

    BEVProgram {                // CCF HbridType == 7	        
        EAC_REQ             delay   20.000  ms;
		EAC_RESP            delay   20.000  ms;
		HVCH_REQ           delay    20.000  ms;
        BLWR_CTRL1_REQ      delay   20.000  ms;
		HVCH_RESP1         delay    20.000  ms;
	    HVCH_RESP2         delay    20.000  ms;
		BLWR_CTRL1_RESP     delay   20.000  ms;
		BLWR_CTRL2_REQ      delay   20.000  ms;
		EAC_REQ             delay   20.000  ms;
		EAC_RESP            delay   20.000  ms;
		BLWR_CTRL2_RESP     delay   20.000  ms;
	    HVCH_REQ           delay    20.000  ms;
	    EXV1_REQ            delay   20.000  ms;    
	    HVCH_RESP1         delay    20.000  ms;
	    HVCH_RESP2         delay    20.000  ms;
        EXV1_RESP           delay   20.000  ms;
  	}
	
	L663AuxBlwrWebastoFBH { // Fitted with Webasto FBH - CCF HbridType != 7, RmtRcvrType_Z_Pt == 1 & Programme == L663 & CCF ClimtCtrlUnit == 11 
