		FBH_WEBASTO_RESP	delay	20.000	ms;
		R_BLWR_RESP			delay	20.000	ms;
		EAC_REQ				delay	20.000	ms;
		EAC_RESP			delay	20.000	ms;
		HVCH_REQ			delay	20.000	ms;
		HVCH_RESP1			delay	20.000	ms;
