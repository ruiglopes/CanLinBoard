Schedule_tables // Schedule Table Definition
{

	NonBEVProgramsEberFBH { // Fitted with Eberspacher FBH - CCF HybridType != 7 and RmtRcvrType_Z_Pt == 0
		FBH_REQ             delay   30.000  ms;
		EAC_REQ             delay   30.000  ms;
		EAC_RESP            delay   30.000  ms;
		BLWR_CTRL1_REQ      delay   30.000  ms;
		BLWR_CTRL1_RESP     delay   30.000  ms;
		BLWR_CTRL2_REQ      delay   30.000  ms;
		BLWR_CTRL2_RESP     delay   30.000  ms;
		FBH_RESP            delay   50.000  ms;
		HVCH_REQ           delay    30.000  ms;
		HVCH_RESP1         delay    30.000  ms;
		HVCH_RESP2         delay    30.000  ms;
		TELESTART_01_REQ    delay   30.000  ms;
		TELESTART_01_RESP   delay   30.000  ms;
		TELESTART_02_REQ    delay   30.000  ms;
		TELESTART_02_RESP   delay   30.000  ms;
   	}
	
	NonBEVProgramsWebastoFBH { // Fitted with Webasto FBH - CCF HbridType != 7 and RmtRcvrType_Z_Pt == 1
		FBH_WEBASTO_REQ     delay   20.000	ms;
		EAC_REQ             delay   20.000	ms;
		EAC_RESP  			delay 	20.000	ms;
		HVCH_REQ  			delay	20.000	ms;
