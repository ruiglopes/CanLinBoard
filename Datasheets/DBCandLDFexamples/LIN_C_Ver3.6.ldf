/****************************************************************************************/
/*                                                                                      */
/* Description: LIN Description file created using Vector's LIN File Editor             */
/* Created:     14.11.2019                                                              */
/* Author:      nminoiu1, Aj                                                             */
/* Version:     3.6                                                                    	*/
/* Project:     IHSW                                                                    */
/* Change Log:  Ver1.0 - Initial Release.                                               */
/*              Ver1.1 - Added the slave nodes BLWR_CTRL1 and BLWR_CTRL2                */
/*              Ver1.2 - Corrected the signal details for EAC module.                   */
/*              Ver1.3 - Diagnostics Frames are added to implement the FBH Sleep Request*/
/*              Ver1.4 - Updated the frame delay specified in the schedule table to     */
/*              fix the issue of processor task overloading.                            */
/*              Ver1.5 - Updated the LDF with details for the new LIN modules added for */
/*              Ver1.6 - Moved the FBH_RESP frame within the schedule table to fix the  */
/*              issue reported in JIRA task 1313.                                       */
/*              Ver1.7 - Following 3 updates have been done as per JIRA ticket 1587     */
/*                1) Correct the frame size of the HVCH_REQ from 8 to 4 bytes.         */
/*                2) Split the schedule tables into 2.                                  */
/*                        a) One for non-BEV programs.                                  */
/*                        b) One for BEV program.                                       */
/*                3) Update the delay time for the EXV2 and SOV valves to match the     */
/*                   sample time of the application module.                             */
/*                4) Updated the packaging info for the signals HVCH_FailHwProtection  */
/*                   and HVCH_WarnOverheat according to the latest LDF from Webasto    */
/*              Ver1.8 - 1) Details for the Webasto FBH and TELESTART module have been  */
/*                       added.                                                         */
/*                       2) Updated the frame delay time and re-arranged the REQ and    */
/*                          RESP frames													*/
/*				Ver1.9 - Following 4 updates have been done as per JIRA ticket 1851		*/
/*						1) The frame timing and message order is changed in				*/
/*							NonBEVProgramsEberFBH Schedule table as it is in 			*/
/*							LINC LDF v1.7												*/
/*						2) TELESTART_01_REQ, TELESTART_01_RESP, TELESTART_02_REQ, 		*/
/*							TELESTART_02_RESP added at the end.							*/
/*						3) The delay time between FBH_REQ and FBH_RESP is 230 ms.		*/
/*						4) The delay time between the FBH_RESP and next FBH_REQ 		*/
/*							is 240 ms.  												*/
/*				Ver2.0 - Following 2 updates have been made:							*/
/*						1) NonBEVProgramsEberFBH schedule table renamed to 				*/
/*							NonBEVPrograms												*/
/*						2) Removed (commented out) NonBEVProgramsWebastoFBH schedule 	*/
/*							tabe to have a common table for both burners	 			*/	
/*              Ver2.1 - Following updates have been made:                              */
/*                      1) Split into 2 schedule table NonBEVProgramsEberFBH and        */
/*                         NonBEVProgramsWebastoFBH again due to compiler tool issue    */
/*                      2) Removed webasto signals. Eberspacher signals shall be used	*/
/*						   for webasto													*/	
/*						3) Both schedule table shall use different names for FBH request*/
/*						   and response 												*/
/*				Ver2.2 - Following updates have been made:								*/
/*                      1) Remove desired power from HVCH as webasto does not support it*/
/*                      2) Added new signal HVCH_TrgtClntTempRes,HVCH_OverheatUnlock, */
/*						   HVCH_TxReserved1, HVCH_OvrheatCnt, HVCH_OutletClntTempRes,*/
/*                         HVCH_CurConsm, HVCH_InletClntTempRes, HVCH_RxReserved1	*/
/*                         HVCH_RxReserved2                                            */
/*                      3) Repackaged transmitted and received HVCH frames             */
/*              Ver2.3 - Following updates have been made:								*/
/*                      1) Repackaged HVCH_REQ frame. 									*/
/*							Moved: 														*/
/*								   HVCH_AmbientTemp to bit 16							*/
/*								   HVCH_OverheatUnlock to bit 24						*/
/*								   HVCH_HeaterEnable to bit 27							*/
/*								   HVCH_TrgtClntTempRes to bit 28						*/
/*               Ver2.4 - Following updates have been made:                             */
/*                      1) Added additional EAC REQ and RESP frame in non-BEV Webasto   */
/*                         schedule table                                               */
/*               Ver2.5 - Updated NonBEVProgramsWebastoFBH schedule table to include    */
/*                        additional HVCH frame and replace 30ms delays with 20ms to 	*/
/*                        reduce overall time.                                          */
/*               Ver3.0 - Removed all Shutoff and EXV2 Valves [Moved to COOLING LINBus  */
/*                        Redefined EXV1 Frames/Signal to Comply to Mahle EXV Spec 2.0  */
/*                        Updated Schedule Table                                        */
/*				 Ver3.1 - Updated Length of LIN Frames Transmitted to and Received      */
/*                        to 8  														*/
/*				 Ver3.2 - Renamed BlwrCtrl1ResUnused1 to BlwrCtrl1Type to support new   */
/*						  blower (JLRHVAC-5715)											*/
/*                      - Renamed BlwrCtrl2ResUnused1 to BlwrCtrl2Type to support new   */
/*						  blower (JLRHVAC-5715)                                         */
/*               Ver3.3 - Added new signals HVCH_StatusExt and HVCH_Type to             */
/*						  HVCH_RESP1   												    */
/*               Ver3.4 - Replaced HVCH Signal Names                                    */
/*               Ver3.6 - Added a new schedule table for a specific programme which     */
/*                        requires different rear blower encoding						*/
/*                                                                                      */
/****************************************************************************************/

// Global Definitions
LIN_description_file;
LIN_protocol_version = "2.0";
LIN_language_version = "2.0";
LIN_speed = 9.600 kbps; // baudrate (1.0-20.0)
// End of Global Definitions

Nodes // Nodes Definition
{
	Master:
		HVAC,           // master node name
		5.000 ms,       // time base (real)
		1.500 ms;       // jitter (real)
			
	Slaves:
		FBH,            // Fuel Burning Heater (AHCM) - Eberspecher 
        EAC,            // Electric A/C Compressor
        BLWR_CTRL1,     // Blower Controller 1 - Could be either Front Blower (if Pin2 is Open) or Rear Blower (if Pin 2 is GND)
        BLWR_CTRL2,     // Blower Controller 2 - Could be either Front Blower (if Pin2 is GND) or Rear Blower (if Pin 2 is Open) 
		R_BLWR,			// Rear Blower Controller - MLA Aux Blower
        HVCH,           // High Voltage Coolant Heater #1
        EXV1,           // Chiller Refrigerant Control Expansion Valve
        FBH_WEBASTO,    // Fuel Burning Heater (AHCM) - Webasto
        TELESTART;      // Telestart module for the Webasto FBH
} // End of Nodes Definition


Signals // Signals Definition
{
	// Signals Transmitted by HVAC to Eberspacher FBH
    FBH_CmdRegByte1:            8,  0x02, HVAC, FBH;  
    FBH_CmdRegByte2:		    8,  0x00, HVAC, FBH;	
    FBH_CmdRegByte3:		    8,  0x00, HVAC,	FBH;    
    FBH_CmdRegByte4: 		    8,	0x00, HVAC,	FBH; 
    FBH_CmdRegByte5:       	    8, 	0x00, HVAC, FBH; 
    FBH_CmdRegByte6:       	    8,  0x00, HVAC,	FBH; 
    FBH_CmdRegByte7:    		8,  0x00, HVAC,	FBH;
    FBH_CmdRegByte8:            8,	0x00, HVAC,	FBH;
    
    // Signals Transmitted by HVAC to EAC
    EAC_TargetSpeed:            8,	0xFF, HVAC, EAC;
    EAC_DriveRequest:           2,	0x3,  HVAC, EAC;
    EAC_TxReserved1:            6,	0x3F, HVAC, EAC;
    EAC_PowerLim:               8,	0xFF, HVAC, EAC;
    EAC_DschgPressure:          16,	0xFFFF, HVAC, EAC;
    EAC_TxReserved2:            8,	0xFF, HVAC, EAC;
    EAC_TxReserved3:            8,	0xFF, HVAC, EAC;
    EAC_TxReserved4:            8,	0xFF, HVAC, EAC;

	// Signals Transmitted by HVAC to Blower Controller 1 (Front Blower or Rear Blower)
    BlwrCtrl1RxFreq:            12, 1896, HVAC, BLWR_CTRL1;
    BlwrCtrl1ReqUnused1:        4,	15,   HVAC, BLWR_CTRL1;
    BlwrCtrl1Select:            2,	0,    HVAC, BLWR_CTRL1;
    BlwrCtrl1ImaxMax:           6,	0,    HVAC, BLWR_CTRL1;
    BlwrCtrl1ImaxMin:           5,	0,    HVAC, BLWR_CTRL1;
    BlwrCtrl1KneeU:             3,	7,    HVAC, BLWR_CTRL1;
    BlwrCtrl1SftyRunThres:      4,	15,   HVAC, BLWR_CTRL1;
    BlwrCtrl1Ramp:              4,	15,   HVAC, BLWR_CTRL1;
    BlwrCtrl1Speed:             8,	0,    HVAC, BLWR_CTRL1;
    BlwrCtrl1SftyRunSpeed:      8,  0,    HVAC, BLWR_CTRL1;
    BlwrCtrl1ReqUnused2:        8,	255,  HVAC, BLWR_CTRL1;

	// Signals Transmitted by HVAC to Blower Controller 2 (Front Blower or Rear Blower)
    BlwrCtrl2RxFreq:            12, 1896, HVAC, BLWR_CTRL2;
    BlwrCtrl2ReqUnused1:        4,	15,   HVAC, BLWR_CTRL2;
    BlwrCtrl2Select:            2,	0,    HVAC, BLWR_CTRL2;
    BlwrCtrl2ImaxMax:           6,	0,    HVAC, BLWR_CTRL2;
    BlwrCtrl2ImaxMin:           5,	0,    HVAC, BLWR_CTRL2;
    BlwrCtrl2KneeU:             3,	7,    HVAC, BLWR_CTRL2;
    BlwrCtrl2SftyRunThres:      4,	15,   HVAC, BLWR_CTRL2;
    BlwrCtrl2Ramp:              4,	15,   HVAC, BLWR_CTRL2;
    BlwrCtrl2Speed:             8,	0,    HVAC, BLWR_CTRL2;
    BlwrCtrl2SftyRunSpeed:      8,  0,    HVAC, BLWR_CTRL2;
    BlwrCtrl2ReqUnused2:        8,	255,  HVAC, BLWR_CTRL2;
	
	// Signals Transmitted by HVAC to Rear Blower Controller
	R_BLWRReqUnused6:	 		12,	0xFFF,		HVAC, R_BLWR;
    R_BLWRReqUnused1:	        4,	0x0F,		HVAC, R_BLWR;
    R_BLWRReqUnused2:	        8,	0xFF,    	HVAC, R_BLWR;
    R_BLWRReqUnused3:	        8,	0xFF,   	HVAC, R_BLWR;
    R_BLWRReqUnused4:	        4,	0x0F,		HVAC, R_BLWR;
    R_BLWRRamp:	                4,	0x07,		HVAC, R_BLWR;
    R_BLWRSpeed:	            8,	0x00,		HVAC, R_BLWR;
    R_BLWRSftyRunSpeed:	        8,  0x00,		HVAC, R_BLWR;
    R_BLWRReqUnused5: 	        8,	0xFF,		HVAC, R_BLWR;	

  	// Signals Transmitted by HVAC to High Voltage Coolant Heater
    HVCH_MaxPower:              8,  255,  HVAC, HVCH;
    HVCH_TrgtClntTemp:    		8,	255,  HVAC, HVCH;
    HVCH_AmbientTemp:           8,	255,  HVAC, HVCH;
    HVCH_HeaterEnable:          1,	0,    HVAC, HVCH;
	HVCH_TrgtClntTempRes:		4,	1,	  HVAC,	HVCH;
	HVCH_OverheatUnlock:		1,	0,	  HVAC,	HVCH;
	HVCH_TxReserved1: 			2,	0,	  HVAC,	HVCH;

    // Signals Transmitted by HVAC to Chiller Refrigerant Control Expansion Valve (EXV#1)
    EXV1_CmdSetReq:				16, 0,    HVAC, EXV1;
	EXV1_TxReserved1:           1,	0,    HVAC, EXV1;
    EXV1_CmdMovEnbl:            1,  0,    HVAC, EXV1;
    EXV1_TxReserved2:           5,	0,    HVAC, EXV1; 
    EXV1_TxReserved3:           5,	0,    HVAC, EXV1;
	EXV1_CmdStallEnbl:			1,	0,    HVAC, EXV1;
	EXV1_CmdInitReq:			3,	0,    HVAC, EXV1;
	EXV1_TxReserved4:           8,	0,    HVAC, EXV1;
	EXV1_TxReserved5:           8,	0,    HVAC, EXV1;
	EXV1_TxReserved6:           8,	0,    HVAC, EXV1;
	EXV1_TxReserved7:           8,	0,    HVAC, EXV1;

    // Signals Transmitted by HVAC to Webasto FBH
    FBH_WEBASTO_CmdRegByte1:    8,  0x02, HVAC, FBH_WEBASTO;  
    FBH_WEBASTO_CmdRegByte2:    8,  0x00, HVAC, FBH_WEBASTO;	
    FBH_WEBASTO_CmdRegByte3:    8,  0x00, HVAC,	FBH_WEBASTO;    
    FBH_WEBASTO_CmdRegByte4:    8,	0x00, HVAC,	FBH_WEBASTO; 
    FBH_WEBASTO_CmdRegByte5:    8, 	0x00, HVAC, FBH_WEBASTO; 
    FBH_WEBASTO_CmdRegByte6:    8,  0x00, HVAC,	FBH_WEBASTO; 
    FBH_WEBASTO_CmdRegByte7: 	8,  0x00, HVAC,	FBH_WEBASTO;
    FBH_WEBASTO_CmdRegByte8:    8,	0x00, HVAC,	FBH_WEBASTO;

    // Signals Transmitted by HVAC to Telestart module
    TELE_HvacInitStats:             1,  1,          HVAC, TELESTART;
    TELE_SetTeleStrtMode:           3,  0,          HVAC, TELESTART;
    TELE_TeleStrtRmtCtrlIdBarCode:  24, {0, 0, 0},  HVAC, TELESTART;
    TELE_TeleStrtRmtCtrlIdReq:      3,  0,          HVAC, TELESTART;
    TELE_SetRmtCtrlIdByBarcode:     1,  0,          HVAC, TELESTART;
    TELE_SetRmtCtrlIdByRadio:       1,  0,          HVAC, TELESTART;
    TELE_HvacParkVentStats:         1,  0,          HVAC, TELESTART;
    TELE_HvacParkHeatStats:         1,  0,          HVAC, TELESTART;
    TELE_SetTeleStrtHeatDurtn:      6,  0,          HVAC, TELESTART;
    TELE_TxReserved1:               15, 0,          HVAC, TELESTART;
    TELE_TxReserved2:               5,  0,          HVAC, TELESTART;
    TELE_TxReserved3:               16, 0,          HVAC, TELESTART;
    TELE_TxReserved4:               7,  0,          HVAC, TELESTART;
    TELE_TxReserved5:               2,  0,          HVAC, TELESTART;
    TELE_TxReserved6:               7,  0,          HVAC, TELESTART;
    
 	// Response Signals from Eberspacher FBH
    FBH_StatsRegByte1:          8,	0x00, FBH, HVAC;
    FBH_StatsRegByte2:          8,	0x00, FBH, HVAC;
    FBH_StatsRegByte3:          8,	0x00, FBH, HVAC;
    FBH_StatsRegByte4:          8,	0x00, FBH, HVAC;
    FBH_StatsRegByte5:          8,	0x00, FBH, HVAC;
    FBH_StatsRegByte6:          8,	0x00, FBH, HVAC;
    FBH_StatsRegByte7:          8,	0x00, FBH, HVAC;
    FBH_StatsRegByte8:          8,	0x00, FBH, HVAC;

    // Response Signals from EAC
	EAC_STAT_REG_1: 			8, 	0xFF, EAC, HVAC;
	EAC_STAT_REG_2: 			8, 	0x03, EAC, HVAC;
	EAC_STAT_REG_3: 			8, 	0xFF, EAC, HVAC;
	EAC_STAT_REG_4: 			8, 	0xFF, EAC, HVAC;
	EAC_STAT_REG_5: 			8, 	0xFF, EAC, HVAC;
	EAC_STAT_REG_6: 			8, 	0xFF, EAC, HVAC;
	EAC_STAT_REG_7: 			8, 	0x00, EAC, HVAC;
	EAC_STAT_REG_8: 			7, 	0x00, EAC, HVAC;
	EAC_RESPError:				1, 	0x00, EAC, HVAC;
    
    // Response Signals from Blower Controller 1 (Front Blower or Rear Blower)
    BlwrCtrl1IntnlErr:          1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1SCOrMtrBlockFault: 1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1OverTempFault:     1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1BrokenLineFault:   1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1HighUFault:        1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1LowUFault:         1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1LINCommFault:      1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1Status1Valid:      1,	0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1CurrentLimitStatus:1,  0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1SetPointReached:   1,  0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1SftyRunStatus:     1,  0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1Status2Valid:      1,  0,      BLWR_CTRL1, HVAC;
    BlwrCtrl1Type:      		4,  0xF,    BLWR_CTRL1, HVAC;
    BlwrCtrl1IBATT:             8,  0xFE,   BLWR_CTRL1, HVAC;
    BlwrCtrl1UMotor:            8,  0xFE,   BLWR_CTRL1, HVAC;
    BlwrCtrl1Temperature:       8,  0xFE,   BLWR_CTRL1, HVAC;
    BlwrCtrl1UBATT:             8,  0xFE,   BLWR_CTRL1, HVAC;
    BlwrCtrl1Supplier:          8,  0x00,   BLWR_CTRL1, HVAC;
    BlwrCtrl1SW:                4,  0x00,   BLWR_CTRL1, HVAC;
    BlwrCtrl1HW:                4,  0x00,   BLWR_CTRL1, HVAC;

    // Response Signals from Blower Controller 2 (Front Blower or Rear Blower)
    BlwrCtrl2IntnlErr:          1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2SCOrMtrBlockFault: 1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2OverTempFault:     1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2BrokenLineFault:   1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2HighUFault:        1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2LowUFault:         1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2LINCommFault:      1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2Status1Valid:      1,	0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2CurrentLimitStatus:1,  0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2SetPointReached:   1,  0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2SftyRunStatus:     1,  0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2Status2Valid:      1,  0,      BLWR_CTRL2, HVAC;
    BlwrCtrl2Type:        		4,  0xF,    BLWR_CTRL2, HVAC;
    BlwrCtrl2IBATT:             8,  0xFE,   BLWR_CTRL2, HVAC;
    BlwrCtrl2UMotor:            8,  0xFE,   BLWR_CTRL2, HVAC;
    BlwrCtrl2Temperature:       8,  0xFE,   BLWR_CTRL2, HVAC;
    BlwrCtrl2UBATT:             8,  0xFE,   BLWR_CTRL2, HVAC;
    BlwrCtrl2Supplier:          8,  0x00,   BLWR_CTRL2, HVAC;
    BlwrCtrl2SW:                4,  0x00,   BLWR_CTRL2, HVAC;
    BlwrCtrl2HW:                4,  0x00,   BLWR_CTRL2, HVAC;
	
	// Response Signals from Rear Blower Controller
    R_BLWRMtrStatus:	       3,	0x00,      	R_BLWR, HVAC;
    R_BLWRDiag1:			   4,	0x00,      	R_BLWR, HVAC;
    R_BLWRRespErr:			   1,	0x00,      	R_BLWR, HVAC;
    R_BLWRDiag2:			   8,	0x00,      	R_BLWR, HVAC;
	R_BLWRIBATT:	           8,   0xFE,   	R_BLWR, HVAC;
    R_BLWRRotatSpd:	           8,	0xFE,   	R_BLWR, HVAC;
	R_BLWRTemperature:	       8,   0xFE,   	R_BLWR, HVAC;
	R_BLWRUBATT:	           8,   0xFE,   	R_BLWR, HVAC;
    R_BLWRSupplier: 	       8,   0x00,   	R_BLWR, HVAC;
	R_BLWRSW:  				   4,   0x00,		R_BLWR,	HVAC;
	R_BLWRHW:				   4,	0x00,		R_BLWR,	HVAC;

    // Response Signals from High Voltage Coolant Heater
    HVCH_Status:                3,	0,      HVCH, HVAC;
	HVCH_StatusExt: 			3, 	0, 		HVCH, HVAC;
	HVCH_Type: 				    2, 	0, 		HVCH, HVAC;
    HVCH_InletClntTemp:         8,	255,    HVCH, HVAC;
    HVCH_OutletClntTemp:        8,	255,    HVCH, HVAC;
    HVCH_HVVoltage:             10,	1023,   HVCH, HVAC;
    HVCH_ActualPower:           10,	1023,   HVCH, HVAC;
    HVCH_RespErr:               1,  0,      HVCH, HVAC;
    HVCH_WarnFltInCom:          2,  3,      HVCH, HVAC;
    HVCH_WarnHiUOutOfRng:       2,  3,      HVCH, HVAC;
    HVCH_WarnLoUOutOfRng:       2,  3,      HVCH, HVAC;
    HVCH_WarnClntTempOutOfRng:  2,  3,      HVCH, HVAC;
    HVCH_FailHwProtection:      2,  3,      HVCH, HVAC;
    HVCH_WarnOverheat:          2,  3,      HVCH, HVAC;
    HVCH_FailInletClntTempSns:  2,  3,      HVCH, HVAC;
    HVCH_FailOutletClntTempSns: 2,  3,      HVCH, HVAC;
    HVCH_FailHeatCoreTempSns:   2,  3,      HVCH, HVAC;
    HVCH_FailHiUDriver:         2,  3,      HVCH, HVAC;
    HVCH_FailHiUCurrentConsump: 2,  3,      HVCH, HVAC;
    HVCH_FailMemory:            2,  3,      HVCH, HVAC;
    HVCH_FailDCDCConverter:     2,  3,      HVCH, HVAC;
	HVCH_OvrheatCnt:			4,	0,		HVCH, HVAC;
	HVCH_OutletClntTempRes: 	4,	1,		HVCH, HVAC;
	HVCH_CurConsm:				8,	255,	HVCH, HVAC;
	HVCH_InletClntTempRes: 	    4,	1,		HVCH, HVAC;
	HVCH_RxReserved1:			5,	0,		HVCH, HVAC;
	HVCH_RxReserved2:			5,	0,		HVCH, HVAC;

    // Response Signals from Chiller Refrigerant Control Expansion Valve (EXV#1)
    EXV1_CommError:             1,	0,      EXV1, HVAC;
	EXV1_FaltStats:				4,	0, 		EXV1, HVAC;
	EXV1_RunStats:				1,	0, 	    EXV1, HVAC;
	EXV1_StallEnblStats:		1,	0, 	    EXV1, HVAC;
    EXV1_InitStats:             2,	0,      EXV1, HVAC;
	EXV1_VoltStats:				2,	0,	    EXV1, HVAC;
	EXV1_OvrTeStats:			2,	0,	    EXV1, HVAC;
    EXV1_SlavePosRprt:          16,	0,      EXV1, HVAC;
    EXV1_RxReserved1:           1,	0,      EXV1, HVAC;
	EXV1_RxReserved2:			2,	0,	    EXV1, HVAC;
	EXV1_RxReserved3:			8,	0,	    EXV1, HVAC;
	EXV1_RxReserved4:			8,	0,	    EXV1, HVAC;
	EXV1_RxReserved5:			8,	0,	    EXV1, HVAC;
	EXV1_RxReserved6:			8,	0,	    EXV1, HVAC;
 

    // Response Signals from Webasto FBH
    FBH_WEBASTO_StatsRegByte1:  8,	0x00,   FBH_WEBASTO, HVAC;
    FBH_WEBASTO_StatsRegByte2:  8,	0x00,   FBH_WEBASTO, HVAC;
    FBH_WEBASTO_StatsRegByte3:  8,	0x00,   FBH_WEBASTO, HVAC;
    FBH_WEBASTO_StatsRegByte4:  8,	0x00,   FBH_WEBASTO, HVAC;
    FBH_WEBASTO_StatsRegByte5:  8,	0x00,   FBH_WEBASTO, HVAC;
    FBH_WEBASTO_StatsRegByte6:  8,	0x00,   FBH_WEBASTO, HVAC;
    FBH_WEBASTO_StatsRegByte7:  8,	0x00,   FBH_WEBASTO, HVAC;
    FBH_WEBASTO_StatsRegByte8:  8,	0x00,   FBH_WEBASTO, HVAC;

    // Response Signals from TELESTART module
    TELE_SigStrength:           8,	254,        TELESTART, HVAC;
    TELE_HwDefectStatus:        1,	0,          TELESTART, HVAC;
    TELE_ResponseError:         1,	0,          TELESTART, HVAC;
    TELE_InitStatus:            1,	0,          TELESTART, HVAC;
