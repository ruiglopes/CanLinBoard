VAL_ 1537 Status 0 "OK" 1 "UnknownCmd" 2 "InvalidParam" 3 "CRCMismatch" 4 "NVMError" 5 "Busy" ;
VAL_ 2032 SysState 0 "BOOT" 1 "OK" 2 "WARN" 3 "ERROR" ;
VAL_ 2032 ResetReason 0 "PowerOn" 1 "WatchdogTimeout" 2 "CrashReboot" 3 "Unknown" ;
VAL_ 2035 FaultType 0 "None" 1 "HardFault" 2 "StackOverflow" 3 "MallocFail" 4 "AssertFail" 5 "WatchdogTimeout" ;
VAL_ 2042 Result 0 "PASS" 1 "FAIL" 2 "SKIP" ;
VAL_ 1536 Cmd 1 "CONNECT" 2 "SAVE" 3 "DEFAULTS" 4 "REBOOT" 5 "ENTER_BL" 6 "GET_STATUS" 16 "READ_PARAM" 17 "WRITE_PARAM" 32 "BULK_START" 33 "BULK_END" 34 "BULK_READ" ;

