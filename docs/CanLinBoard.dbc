CM_ BU_ Board "CAN/LIN gateway board (RP2350, FreeRTOS). CAN1 always on, CAN2 switchable.";
CM_ BU_ Host "External host tool (Windows config app or PCAN test script).";

CM_ BO_ 1536 "Config command from host. Byte 0 = command code; remaining bytes are command-specific. See config_protocol.h for full details.\n\nCmd values:\n  0x01 CONNECT - no payload, returns FW version\n  0x02 SAVE - save working config to NVM\n  0x03 DEFAULTS - reset config to factory defaults\n  0x04 REBOOT - MCU software reset\n  0x05 ENTER_BL - bytes 1-4: unlock key 0xB007CAFE (LE)\n  0x06 GET_STATUS - returns NVM write count\n  0x10 READ_PARAM - bytes 1-3: section/param/sub\n  0x11 WRITE_PARAM - bytes 1-3: section/param/sub, bytes 4+: value (LE)\n  0x20 BULK_START - byte 1: section, byte 2: sub, bytes 3-4: size (LE), bytes 5-7: CRC24 (LE, lower 24 bits of CRC32)\n  0x21 BULK_END - finalize bulk transfer\n  0x22 BULK_READ - byte 1: section (0x02=routing, 0x01=LIN), byte 2: sub (LIN channel). Response on 0x601 then data on 0x603";

CM_ BO_ 1537 "Config response from board. Byte 0 echoes the command; byte 1 = status code; bytes 2+ are command-specific payload.\n\nCONNECT response (DLC=8): bytes 2-4: FW major/minor/patch, bytes 5-6: sizeof(nvm_config_t) LE, byte 7: routing rule count.\nGET_STATUS response (DLC=6): bytes 2-5: NVM write count (LE).\nREAD_PARAM response: bytes 2-4: section/param/sub echo, bytes 5+: value (LE).";

CM_ BO_ 1538 "Bulk data frames during bulk write transfer (host to board). Byte 0 = sequence number (0,1,2,...). Bytes 1-7 = payload (up to 7 bytes per frame). No individual ACK per frame; send BULK_END (0x21) to finalize.";

CM_ BO_ 1539 "Bulk data response frames during bulk read transfer (board to host). Sent after a BULK_READ (0x22) command response. Byte 0 = sequence number (0,1,2,...). Bytes 1-7 = payload (up to 7 bytes per frame). Host reads total size from the BULK_READ response header.";

CM_ BO_ 1792 "Bootloader reboot trigger handled by application firmware. Cmd must be 0x05 (CMD_RESET), Mode must be 0x01 (RESET_MODE_BOOTLOADER). UnlockKey = 0xB007CAFE (little-endian). Board writes SRAM magic and reboots immediately (no response sent). Other 0x700 commands are handled by the bootloader only.";

CM_ BO_ 2032 "Diagnostic heartbeat, sent every 1 second on CAN1.\n\nNote: A one-shot boot frame (DLC=6) is sent once at startup with a different format:\n  bytes 0-2: FW version major/minor/patch\n  byte 3: 0xAA sentinel\n  bytes 4-5: app CRC32 bits [15:0] (big-endian)";

CM_ BO_ 2033 "CAN bus and gateway statistics, sent every 1 second (5 ms after DIAG_Status). All counters are lower 16 or 8 bits, wrapping.";

CM_ BO_ 2034 "LIN channel statistics for all 4 channels, sent every 1 second (10 ms after DIAG_Status). 2 bytes per channel: RX count (saturated at 255) and error count (saturated at 255).";

CM_ BO_ 2035 "Crash report, sent once at boot if a valid crash record exists in watchdog scratch registers. Cleared after transmission. Only present if the previous boot ended in a fault.";

CM_ BO_ 2036 "System health indicators, sent every 1 second (15 ms after DIAG_Status). Heap, stack watermark, and bus watchdog timeout monitoring.";

CM_ BO_ 2042 "Test result frame (test firmware only). Sent once per test case. TestID = test number within the phase. Result: 0=PASS, 1=FAIL, 2=SKIP. Bytes 2-7 may carry test-specific auxiliary data.";

CM_ BO_ 2043 "Test summary frame (test firmware only). Sent once at end of a test run. Sentinel is always 0xAA.";

CM_ SG_ 1536 Cmd "Config command code. See config_protocol.h for values.";
CM_ SG_ 1537 EchoCmd "Echo of the command code that generated this response.";
CM_ SG_ 1537 Status "Response status: 0=OK, 1=UnknownCmd, 2=InvalidParam, 3=CRCMismatch, 4=NVMError, 5=Busy.";
CM_ SG_ 1538 SeqNum "Sequence counter starting at 0, incrementing per bulk data frame. Sequence error aborts the transfer.";
CM_ SG_ 1792 Cmd "Must be 0x05 (CMD_RESET).";
CM_ SG_ 1792 Mode "Must be 0x01 (RESET_MODE_BOOTLOADER).";
CM_ SG_ 1792 UnlockKey "Reset unlock key = 0xB007CAFE (little-endian).";
CM_ SG_ 2032 Uptime_s "Seconds since boot (32-bit, big-endian).";
CM_ SG_ 2032 SysState "System state enum: 0=BOOT, 1=OK, 2=WARN, 3=ERROR.";
CM_ SG_ 2032 BusMask "Active bus bitmask: bit0=CAN1, bit1=CAN2, bit2=LIN1, bit3=LIN2, bit4=LIN3, bit5=LIN4.";
CM_ SG_ 2032 MCU_Temp "RP2350 die temperature (signed). Formula: T = 27 - (V - 0.706) / 0.001721.";
CM_ SG_ 2032 ResetReason "Reset reason enum: 0=PowerOn, 1=WatchdogTimeout, 2=CrashReboot, 3=Unknown.";
CM_ SG_ 2033 CAN1_RxCount "CAN1 received frame count (lower 16 bits, wrapping).";
CM_ SG_ 2033 CAN1_ErrCount "CAN1 error count (saturated at 255).";
CM_ SG_ 2033 CAN2_RxCount "CAN2 received frame count (lower 16 bits, wrapping).";
CM_ SG_ 2033 CAN2_ErrCount "CAN2 error count (saturated at 255).";
CM_ SG_ 2033 GW_RoutedCount "Gateway routed frame count (lower 16 bits, wrapping).";
CM_ SG_ 2034 LIN1_RxCount "LIN channel 1 RX frame count (saturated at 255).";
CM_ SG_ 2034 LIN1_ErrCount "LIN channel 1 error count (saturated at 255).";
CM_ SG_ 2034 LIN2_RxCount "LIN channel 2 RX frame count (saturated at 255).";
CM_ SG_ 2034 LIN2_ErrCount "LIN channel 2 error count (saturated at 255).";
CM_ SG_ 2034 LIN3_RxCount "LIN channel 3 RX frame count (saturated at 255).";
CM_ SG_ 2034 LIN3_ErrCount "LIN channel 3 error count (saturated at 255).";
CM_ SG_ 2034 LIN4_RxCount "LIN channel 4 RX frame count (saturated at 255).";
CM_ SG_ 2034 LIN4_ErrCount "LIN channel 4 error count (saturated at 255).";
CM_ SG_ 2035 FaultType "Fault type enum: 0=None, 1=HardFault, 2=StackOverflow, 3=MallocFail, 4=AssertFail, 5=WatchdogTimeout.";
CM_ SG_ 2035 PC "Program counter at fault location (32-bit, big-endian). Thumb addresses have bit 0 set.";
CM_ SG_ 2035 CrashUptime_s "Uptime in seconds when the crash occurred (big-endian, 16-bit).";
CM_ SG_ 2035 TaskNameChar "First ASCII character of the faulting FreeRTOS task name.";
CM_ SG_ 2036 HeapFree_KB "Free FreeRTOS heap in kilobytes.";
CM_ SG_ 2036 MinStackWatermark "Minimum stack high-water mark across all tasks (in words, saturated at 255).";
CM_ SG_ 2036 WdtTimeoutMask "Bus software watchdog timeout bitmask: bit0=CAN1, bit1=CAN2, bit2=LIN1, bit3=LIN2, bit4=LIN3, bit5=LIN4. 0=no timeout.";


BA_DEF_ BO_ "GenMsgCycleTime" INT 0 10000;
