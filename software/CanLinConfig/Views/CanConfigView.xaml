<UserControl x:Class="CanLinConfig.Views.CanConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <StackPanel>
            <!-- CAN1 -->
            <GroupBox Header="CAN1 (Always On)" Margin="0,0,0,15">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Bitrate:" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="0" Grid.Column="1" IsEditable="True"
                              Text="{Binding Can1.Bitrate, UpdateSourceTrigger=LostFocus}"
                              Width="150" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <ComboBoxItem Content="125000" />
                        <ComboBoxItem Content="250000" />
                        <ComboBoxItem Content="500000" />
                        <ComboBoxItem Content="1000000" />
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Termination:" VerticalAlignment="Center" />
                    <mah:ToggleSwitch Grid.Row="1" Grid.Column="1" IsOn="{Binding Can1.Termination}" OnContent="ON" OffContent="OFF" />
                </Grid>
            </GroupBox>

            <!-- CAN2 -->
            <GroupBox Header="CAN2 (Switchable)" Margin="0,0,0,15">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Enabled:" VerticalAlignment="Center" />
                    <mah:ToggleSwitch Grid.Row="0" Grid.Column="1" IsOn="{Binding Can2.Enabled}" OnContent="ON" OffContent="OFF" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Bitrate:" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1" IsEditable="True"
                              Text="{Binding Can2.Bitrate, UpdateSourceTrigger=LostFocus}"
                              Width="150" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <ComboBoxItem Content="125000" />
                        <ComboBoxItem Content="250000" />
                        <ComboBoxItem Content="500000" />
                        <ComboBoxItem Content="1000000" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Termination:" VerticalAlignment="Center" />
                    <mah:ToggleSwitch Grid.Row="2" Grid.Column="1" IsOn="{Binding Can2.Termination}" OnContent="ON" OffContent="OFF" />
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
