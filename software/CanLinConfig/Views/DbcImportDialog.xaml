<mah:MetroWindow x:Class="CanLinConfig.Views.DbcImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Import from DBC" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Messages found -->
        <TextBlock Grid.Row="0" Text="Messages found in DBC:" FontWeight="SemiBold" Margin="0,0,0,5" />

        <ListBox Grid.Row="1" x:Name="MessageList" Height="120"
                 SelectionMode="Single" DisplayMemberPath="DisplayText" />

        <!-- Assignment -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Control (CAN→LIN):" VerticalAlignment="Center" Grid.Row="0" />
            <ComboBox x:Name="ControlCombo" Grid.Row="0" Grid.Column="1"
                      DisplayMemberPath="DisplayText" Margin="0,2" />

            <TextBlock Text="Status (LIN→CAN):" VerticalAlignment="Center" Grid.Row="1" />
            <ComboBox x:Name="StatusCombo" Grid.Row="1" Grid.Column="1"
                      DisplayMemberPath="DisplayText" Margin="0,2" />
        </Grid>

        <!-- Signal preview -->
        <GroupBox Grid.Row="3" Header="Signals Preview" Margin="0,10,0,0">
            <DataGrid x:Name="SignalPreview" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140" />
                    <DataGridTextColumn Header="Bits" Binding="{Binding BitInfo}" Width="80" />
                    <DataGridTextColumn Header="Factor" Binding="{Binding Factor}" Width="60" />
                    <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="100" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Import" Click="OnImport" Width="80" Margin="0,0,10,0" />
            <Button Content="Cancel" Click="OnCancel" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
