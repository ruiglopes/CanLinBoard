<UserControl x:Class="CanLinConfig.Views.DiagConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <GroupBox Header="Diagnostics Configuration" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Enabled:" VerticalAlignment="Center" />
                <mah:ToggleSwitch Grid.Row="0" Grid.Column="1" IsOn="{Binding Enabled}" OnContent="ON" OffContent="OFF" Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="CAN ID (hex):" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CanIdHex, UpdateSourceTrigger=LostFocus}" Width="100" HorizontalAlignment="Left" Margin="0,0,0,8" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Interval (ms):" VerticalAlignment="Center" />
                <mah:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding IntervalMs}" Minimum="0" Maximum="60000" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Bus:" VerticalAlignment="Center" />
                <ComboBox Grid.Row="3" Grid.Column="1" SelectedIndex="{Binding Bus}" Width="100" HorizontalAlignment="Left" Margin="0,0,0,8">
                    <ComboBoxItem Content="CAN1" />
                    <ComboBoxItem Content="CAN2" />
                </ComboBox>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="CAN Watchdog (ms):" VerticalAlignment="Center" />
                <mah:NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding CanWatchdogMs}" Minimum="0" Maximum="65535" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="LIN Watchdog (ms):" VerticalAlignment="Center" />
                <mah:NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding LinWatchdogMs}" Minimum="0" Maximum="65535" Width="120" HorizontalAlignment="Left" />
            </Grid>
        </GroupBox>
    </ScrollViewer>
</UserControl>
