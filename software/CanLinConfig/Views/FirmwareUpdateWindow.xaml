<mah:MetroWindow x:Class="CanLinConfig.Views.FirmwareUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:views="clr-namespace:CanLinConfig.Views"
        Title="Firmware Update" Height="680" Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <views:InverseBoolConverter x:Key="InverseBoolConverter" />
        <views:InverseBoolToVisConverter x:Key="InverseBoolToVis" />
        <views:BoolToGreenRedBrushConverter x:Key="BoolToGreenRedBrush" />
    </mah:MetroWindow.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Setup Panel -->
        <GroupBox Grid.Row="0" Header="Setup" Margin="0,0,0,6">
            <StackPanel Margin="6">
                <!-- Firmware file -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Firmware:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding FirmwarePath, Mode=OneWay}" IsReadOnly="True"
                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseFirmwareCommand}"
                            IsEnabled="{Binding IsFlashing, Converter={StaticResource InverseBoolConverter}}"
                            Padding="12,4" />
                </Grid>
                <TextBlock Text="{Binding FirmwareStatus}"
                           Foreground="{Binding FirmwareValid, Converter={StaticResource BoolToGreenRedBrush}}"
                           TextWrapping="Wrap" Margin="0,0,0,8" />

                <!-- HMAC Key -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="HMAC Key:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <!-- File browse mode -->
                    <TextBlock Grid.Column="1" Text="{Binding KeyStatus}" VerticalAlignment="Center"
                               Foreground="{Binding KeyLoaded, Converter={StaticResource BoolToGreenRedBrush}}"
                               Visibility="{Binding UseHexInput, Converter={StaticResource InverseBoolToVis}}" />
                    <!-- Hex input mode -->
                    <TextBox Grid.Column="1" Text="{Binding KeyHexInput, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" Margin="0,0,8,0"
                             mah:TextBoxHelper.Watermark="64 hex characters (32 bytes)"
                             Visibility="{Binding UseHexInput, Converter={StaticResource BoolToVis}}" />
                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseKeyCommand}"
                            IsEnabled="{Binding IsFlashing, Converter={StaticResource InverseBoolConverter}}"
                            Visibility="{Binding UseHexInput, Converter={StaticResource InverseBoolToVis}}"
                            Padding="12,4" Margin="0,0,8,0" />
                    <CheckBox Grid.Column="3" Content="Hex input" IsChecked="{Binding UseHexInput}"
                              VerticalAlignment="Center"
                              IsEnabled="{Binding IsFlashing, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
                <!-- Key status in hex mode -->
                <TextBlock Text="{Binding KeyStatus}"
                           Foreground="{Binding KeyLoaded, Converter={StaticResource BoolToGreenRedBrush}}"
                           Visibility="{Binding UseHexInput, Converter={StaticResource BoolToVis}}"
                           Margin="0,0,0,4" />
                <CheckBox Content="Remember key file path" IsChecked="{Binding RememberKeyPath}"
                          Margin="0,0,0,8"
                          IsEnabled="{Binding IsFlashing, Converter={StaticResource InverseBoolConverter}}" />

                <!-- Options row -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bootloader bitrate:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding BitrateOptions}"
                              SelectedItem="{Binding SelectedBitrate}" Width="110"
                              IsEnabled="{Binding IsFlashing, Converter={StaticResource InverseBoolConverter}}"
                              Margin="0,0,20,0" />
                    <CheckBox Grid.Column="2" Content="Delta update" IsChecked="{Binding DeltaUpdate}"
                              VerticalAlignment="Center"
                              IsEnabled="{Binding IsFlashing, Converter={StaticResource InverseBoolConverter}}"
                              Margin="0,0,20,0" />
                    <TextBlock Grid.Column="3" Text="{Binding TargetBankText}" VerticalAlignment="Center"
                               Foreground="CornflowerBlue" />
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Progress Panel -->
        <GroupBox Grid.Row="1" Header="Progress" Margin="0,0,0,6">
            <StackPanel Margin="6">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StageText}" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding CounterText}" Foreground="Gray" />
                </Grid>
                <ProgressBar Height="20"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                             Maximum="100" />
            </StackPanel>
        </GroupBox>

        <!-- Log Panel -->
        <GroupBox Grid.Row="2" Header="Log">
            <TextBox x:Name="LogTextBox"
                     Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     FontFamily="Consolas" FontSize="12"
                     Background="#FF1E1E1E"
                     Foreground="#FFDCDCDC"
                     TextChanged="LogTextBox_TextChanged" />
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Start" Command="{Binding StartFlashCommand}"
                    IsEnabled="{Binding CanStart}" Padding="20,6" Margin="0,0,8,0" />
            <Button Content="Cancel" Command="{Binding CancelFlashCommand}"
                    IsEnabled="{Binding IsFlashing}" Padding="20,6" Margin="0,0,8,0" />
            <Button Content="Close" Click="CloseButton_Click"
                    IsEnabled="{Binding CanClose}" Padding="20,6" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
