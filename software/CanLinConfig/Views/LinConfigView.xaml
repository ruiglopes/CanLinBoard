<UserControl x:Class="CanLinConfig.Views.LinConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Channel Tabs -->
        <TabControl Grid.Row="1" ItemsSource="{Binding Channels}" SelectedIndex="{Binding SelectedChannelIndex}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ChannelName}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Enabled:" VerticalAlignment="Center" />
                                <mah:ToggleSwitch Grid.Row="0" Grid.Column="1" IsOn="{Binding Enabled}" OnContent="ON" OffContent="OFF" Margin="0,0,0,8" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Mode:" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="1" Grid.Column="1" SelectedIndex="{Binding Mode}" Width="150" HorizontalAlignment="Left" Margin="0,0,0,8">
                                    <ComboBoxItem Content="Disabled" />
                                    <ComboBoxItem Content="Master" />
                                    <ComboBoxItem Content="Slave" />
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Baud Rate:" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="2" Grid.Column="1" IsEditable="True"
                                          Text="{Binding Baudrate, UpdateSourceTrigger=LostFocus}"
                                          Width="150" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="9600" />
                                    <ComboBoxItem Content="19200" />
                                </ComboBox>
                            </Grid>

                            <!-- Schedule Table (Master mode only) -->
                            <GroupBox Header="Schedule Table" Visibility="{Binding IsMaster, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <Button Content="Add" Command="{Binding AddEntryCommand}" Width="60" Margin="0,0,5,0" />
                                        <Button Content="Remove" Command="{Binding RemoveEntryCommand}" Width="60" Margin="0,0,5,0" />
                                        <Button Content="Up" Command="{Binding MoveUpCommand}" Width="40" Margin="0,0,5,0" />
                                        <Button Content="Down" Command="{Binding MoveDownCommand}" Width="50" />
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding Schedule}" AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False" MinHeight="150">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID (hex)" Binding="{Binding Id, StringFormat=X2}" Width="70" />
                                            <DataGridTextColumn Header="DLC" Binding="{Binding Dlc}" Width="50" />
                                            <DataGridComboBoxColumn Header="Direction" SelectedValueBinding="{Binding Direction}" Width="100">
                                                <DataGridComboBoxColumn.ItemsSource>
                                                    <x:Array Type="{x:Type sys:Byte}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                        <sys:Byte>0</sys:Byte>
                                                        <sys:Byte>1</sys:Byte>
                                                    </x:Array>
                                                </DataGridComboBoxColumn.ItemsSource>
                                            </DataGridComboBoxColumn>
                                            <DataGridTextColumn Header="Data (hex)" Binding="{Binding DataHex}" Width="200" />
                                            <DataGridTextColumn Header="Delay (ms)" Binding="{Binding DelayMs}" Width="80" />
                                            <DataGridCheckBoxColumn Header="Classic CS" Binding="{Binding ClassicChecksum}" Width="80" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>
