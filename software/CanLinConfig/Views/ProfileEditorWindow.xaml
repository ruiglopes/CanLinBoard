<mah:MetroWindow x:Class="CanLinConfig.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:views="clr-namespace:CanLinConfig.Views"
        Title="Profile Editor" Height="780" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <views:InverseBoolToVisConverter x:Key="InverseBoolToVis" />
        <views:HexUInt32Converter x:Key="Hex3Converter" Digits="3" />
        <views:HexUInt32Converter x:Key="Hex2Converter" Digits="2" />
        <views:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
    </mah:MetroWindow.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- Tab 1: Basic Info + LIN Config -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Profile Information" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Name:" VerticalAlignment="Center" Grid.Row="0" />
                            <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="0,2" />
                            <TextBlock Text="Version:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="2" Margin="10,0,5,0" />
                            <TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="3" Margin="0,2" />

                            <TextBlock Text="ID:" VerticalAlignment="Center" Grid.Row="1" />
                            <TextBox Text="{Binding ProfileId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,2" />

                            <TextBlock Text="Description:" VerticalAlignment="Center" Grid.Row="2" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                     Margin="0,2" TextWrapping="Wrap" AcceptsReturn="True" Height="60" />
                        </Grid>

                        <Separator Margin="0,15" />
                        <TextBlock Text="LIN Configuration" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Mode:" VerticalAlignment="Center" Width="80" />
                            <ComboBox SelectedItem="{Binding LinMode}" Width="120" Margin="0,0,15,0">
                                <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">master</sys:String>
                                <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">slave</sys:String>
                            </ComboBox>
                            <TextBlock Text="Baud Rate:" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <ComboBox IsEditable="True" Text="{Binding LinBaudrate}" Width="100">
                                <ComboBoxItem Content="9600" />
                                <ComboBoxItem Content="19200" />
                            </ComboBox>
                            <TextBlock Text=" bps" VerticalAlignment="Center" />
                        </StackPanel>

                        <Button Content="Import from LDF..." Command="{Binding ImportLdfCommand}"
                                Width="140" HorizontalAlignment="Left" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Schedule Table -->
            <TabItem Header="Schedule">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="LIN Schedule Table" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" />
                        <Button Content="Add" Command="{Binding AddScheduleEntryCommand}" Width="60" Margin="0,0,5,0" />
                        <Button Content="Remove" Command="{Binding RemoveScheduleEntryCommand}" Width="70" />
                        <TextBlock Text="{Binding ScheduleEntries.Count, StringFormat='  {0} entries'}" VerticalAlignment="Center" Margin="10,0" />
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ScheduleEntries}" SelectedItem="{Binding SelectedScheduleEntry}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Frame ID" Binding="{Binding Id}" Width="80" />
                            <DataGridTextColumn Header="DLC" Binding="{Binding Dlc}" Width="60" />
                            <DataGridComboBoxColumn Header="Direction" SelectedValueBinding="{Binding Direction}" Width="100">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>publish</sys:String>
                                                    <sys:String>subscribe</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>publish</sys:String>
                                                    <sys:String>subscribe</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="Interval (ms)" Binding="{Binding IntervalMs}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 3: CAN Mappings -->
            <TabItem Header="CAN Mappings">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="160" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Mapping list header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="CAN ↔ LIN Mappings" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" />
                        <Button Content="Add" Command="{Binding AddCanMappingCommand}" Width="60" Margin="0,0,5,0" />
                        <Button Content="Remove" Command="{Binding RemoveCanMappingCommand}" Width="70" Margin="0,0,5,0" />
                        <Button Content="Import from DBC..." Command="{Binding ImportDbcCommand}" Width="130" Margin="10,0,0,0" />
                    </StackPanel>

                    <!-- Mapping list -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding CanMappings}" SelectedItem="{Binding SelectedCanMapping}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                            <DataGridComboBoxColumn Header="Direction" SelectedValueBinding="{Binding Direction}" Width="80">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>control</sys:String>
                                                    <sys:String>status</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>control</sys:String>
                                                    <sys:String>status</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="CAN ID" Binding="{Binding CanId, Converter={StaticResource Hex3Converter}}" Width="80" />
                            <DataGridTextColumn Header="LIN Frame ID" Binding="{Binding LinFrameId}" Width="90" />
                            <DataGridCheckBoxColumn Header="Signal Mode" Binding="{Binding UseSignalMode}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Detail header -->
                    <TextBlock Grid.Row="2" Text="Selected Mapping Detail" FontWeight="SemiBold" Margin="0,8,0,5"
                               Visibility="{Binding SelectedCanMapping, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- Detail panel: signals / byte maps for selected mapping -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                  DataContext="{Binding SelectedCanMapping}">
                        <StackPanel Margin="0" Visibility="{Binding Converter={StaticResource NullToCollapsedConverter}}">
                            <!-- Signal mode -->
                            <StackPanel Visibility="{Binding UseSignalMode, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="Signals" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <Button Content="Add" Command="{Binding DataContext.AddSignalCommand, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                            Width="50" Margin="0,0,5,0" />
                                    <Button Content="Remove" Command="{Binding DataContext.RemoveSignalCommand, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                            Width="70" />
                                </StackPanel>
                                <DataGrid ItemsSource="{Binding Signals}" SelectedItem="{Binding SelectedSignal}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120" />
                                        <DataGridTextColumn Header="Start Bit" Binding="{Binding StartBit}" Width="70" />
                                        <DataGridTextColumn Header="Length" Binding="{Binding BitLength}" Width="60" />
                                        <DataGridComboBoxColumn Header="Byte Order" SelectedValueBinding="{Binding ByteOrder}" Width="100">
                                            <DataGridComboBoxColumn.ElementStyle>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="ItemsSource">
                                                        <Setter.Value>
                                                            <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                                <sys:String>little_endian</sys:String>
                                                                <sys:String>big_endian</sys:String>
                                                            </x:Array>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </DataGridComboBoxColumn.ElementStyle>
                                            <DataGridComboBoxColumn.EditingElementStyle>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="ItemsSource">
                                                        <Setter.Value>
                                                            <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                                <sys:String>little_endian</sys:String>
                                                                <sys:String>big_endian</sys:String>
                                                            </x:Array>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </DataGridComboBoxColumn.EditingElementStyle>
                                        </DataGridComboBoxColumn>
                                        <DataGridCheckBoxColumn Header="Signed" Binding="{Binding IsSigned}" Width="55" />
                                        <DataGridTextColumn Header="Factor" Binding="{Binding Factor}" Width="60" />
                                        <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="60" />
                                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <!-- Byte mode -->
                            <StackPanel Visibility="{Binding UseSignalMode, Converter={StaticResource InverseBoolToVis}}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="Byte Maps" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <Button Content="Add" Command="{Binding DataContext.AddByteMapCommand, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                            Width="50" Margin="0,0,5,0" />
                                    <Button Content="Remove" Command="{Binding DataContext.RemoveByteMapCommand, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                            Width="70" />
                                </StackPanel>
                                <DataGrid ItemsSource="{Binding ByteMaps}" SelectedItem="{Binding SelectedByteMap}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Src Byte" Binding="{Binding SrcByte}" Width="100" />
                                        <DataGridTextColumn Header="Dst Byte" Binding="{Binding DstByte}" Width="100" />
                                        <DataGridTextColumn Header="Mask" Binding="{Binding Mask, Converter={StaticResource Hex2Converter}}" Width="80" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 4: Parameters -->
            <TabItem Header="Parameters">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Device Parameters" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" />
                        <Button Content="Add" Command="{Binding AddParameterCommand}" Width="60" Margin="0,0,5,0" />
                        <Button Content="Remove" Command="{Binding RemoveParameterCommand}" Width="70" Margin="0,0,5,0" />
                        <Button Content="Auto from Signals" Command="{Binding AutoParametersFromSignalsCommand}" Width="120" />
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Parameters}" SelectedItem="{Binding SelectedParameter}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120" />
                            <DataGridComboBoxColumn Header="Type" SelectedValueBinding="{Binding Type}" Width="80">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>numeric</sys:String>
                                                    <sys:String>enum</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>numeric</sys:String>
                                                    <sys:String>enum</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="Options (comma-sep)" Binding="{Binding OptionsText}" Width="140" />
                            <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="50" />
                            <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="50" />
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60" />
                            <DataGridTextColumn Header="Byte" Binding="{Binding CanControlByte}" Width="50" />
                            <DataGridTextColumn Header="Mask" Binding="{Binding Mask, Converter={StaticResource Hex2Converter}}" Width="55" />
                            <DataGridComboBoxColumn Header="Frame" SelectedValueBinding="{Binding Frame}" Width="70">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>control</sys:String>
                                                    <sys:String>status</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>control</sys:String>
                                                    <sys:String>status</sys:String>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Click="OnSave" Width="80" Margin="0,0,10,0" IsDefault="True" />
            <Button Content="Cancel" Click="OnCancel" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
