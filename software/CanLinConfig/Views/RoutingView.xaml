<UserControl x:Class="CanLinConfig.Views.RoutingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:views="clr-namespace:CanLinConfig.Views">
    <UserControl.Resources>
        <views:HexUInt32Converter x:Key="Hex3Converter" Digits="3" />
        <views:HexUInt32Converter x:Key="Hex2Converter" Digits="2" />
        <ObjectDataProvider x:Key="BusItems" ObjectType="{x:Type views:BusItem}" MethodName="get_All" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- Rules Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Button Content="Add Rule" Command="{Binding AddRuleCommand}" Width="80" Margin="0,0,5,0" />
            <Button Content="Remove Rule" Command="{Binding RemoveRuleCommand}" Width="90" />
            <TextBlock Text="{Binding Rules.Count, StringFormat='  {0} rules'}" VerticalAlignment="Center" Margin="10,0" />
        </StackPanel>

        <!-- Rules DataGrid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="65" />
                <DataGridComboBoxColumn Header="Src Bus" SelectedValueBinding="{Binding SrcBus}"
                                        SelectedValuePath="Value" DisplayMemberPath="Name"
                                        ItemsSource="{Binding Source={StaticResource BusItems}}" Width="80" />
                <DataGridTextColumn Header="Src ID" Binding="{Binding SrcId, Converter={StaticResource Hex3Converter}}" Width="80" />
                <DataGridTextColumn Header="Src Mask" Binding="{Binding SrcMask, Converter={StaticResource Hex3Converter}}" Width="80" />
                <DataGridComboBoxColumn Header="Dst Bus" SelectedValueBinding="{Binding DstBus}"
                                        SelectedValuePath="Value" DisplayMemberPath="Name"
                                        ItemsSource="{Binding Source={StaticResource BusItems}}" Width="80" />
                <DataGridTextColumn Header="Dst ID" Binding="{Binding DstId, Converter={StaticResource Hex3Converter}}" Width="90" />
                <DataGridTextColumn Header="DLC" Binding="{Binding DstDlc}" Width="50" />
                <DataGridTextColumn Header="Maps" Binding="{Binding Mappings.Count}" Width="50" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Byte Mapping Section -->
        <TextBlock Grid.Row="2" Text="Byte Mappings (selected rule)" Margin="0,10,0,5" FontWeight="SemiBold" />
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,3">
                <Button Content="Add Mapping" Command="{Binding AddMappingCommand}" Width="100" Margin="0,0,5,0" />
                <Button Content="Remove" Command="{Binding RemoveMappingCommand}" Width="70" />
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedRule.Mappings}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Src Byte" Binding="{Binding SrcByte}" Width="80" />
                    <DataGridTextColumn Header="Dst Byte" Binding="{Binding DstByte}" Width="80" />
                    <DataGridTextColumn Header="Mask" Binding="{Binding Mask, Converter={StaticResource Hex2Converter}}" Width="70" />
                    <DataGridTextColumn Header="Shift" Binding="{Binding Shift}" Width="60" />
                    <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
